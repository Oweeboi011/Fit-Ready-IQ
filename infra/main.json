            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "3756087796013876544"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "The Azure region for the Container App."
              }
            },
            "name": {
              "type": "string",
              "metadata": {
                "description": "The name of the frontend Container App."
              }
            },
            "containerAppsEnvironmentId": {
              "type": "string",
              "metadata": {
                "description": "The Container Apps environment ID."
              }
            },
            "acrLoginServer": {
              "type": "string",
              "metadata": {
                "description": "The ACR login server (e.g. myacr.azurecr.io)."
              }
            },
            "managedIdentityId": {
              "type": "string",
              "metadata": {
                "description": "The resource ID of the user-assigned managed identity."
              }
            },
            "managedIdentityClientId": {
              "type": "string",
              "metadata": {
                "description": "The client ID of the user-assigned managed identity."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Resource tags."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "tags": "[union(parameters('tags'), createObject('azd-service-name', 'frontend'))]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', parameters('managedIdentityId'))]": {}
                }
              },
              "properties": {
                "environmentId": "[parameters('containerAppsEnvironmentId')]",
                "workloadProfileName": "Consumption",
                "configuration": {
                  "ingress": {
                    "external": true,
                    "targetPort": 3000,
                    "transport": "auto",
                    "allowInsecure": false
                  },
                  "registries": [
                    {
                      "server": "[parameters('acrLoginServer')]",
                      "identity": "[parameters('managedIdentityId')]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "frontend",
                      "image": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      },
                      "env": [
                        {
                          "name": "NEXT_PUBLIC_APP_NAME",
                          "value": "Fit-Ready-IQ"
                        },
                        {
                          "name": "NODE_ENV",
                          "value": "production"
                        },
                        {
                          "name": "AZURE_CLIENT_ID",
                          "value": "[parameters('managedIdentityClientId')]"
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": 3,
                    "rules": [
                      {
                        "name": "http-scaling",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "10"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          ],
          "outputs": {
            "fqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('name')), '2024-03-01').configuration.ingress.fqdn]"
            },
            "name": {
              "type": "string",
              "value": "[parameters('name')]"
            },
            "id": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/containerApps', parameters('name'))]"
            }
          }
        }
      },
      "dependsOn": [
        "acr",
        "containerAppsEnv",
        "googleMapsSecret",
        "identity"
      ]
