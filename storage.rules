rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User-specific files (e.g. GPX uploads, profile photos)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Route assets — readable by all authenticated users, writable by backend only
    match /routes/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
