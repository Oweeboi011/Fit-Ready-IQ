# ────────────────────────────────────────────────────────────────
# Fit-Ready-IQ — Environment Variables
# Copy this file to .env.local for local development.
# .env.local is gitignored. Never commit real values.
# ────────────────────────────────────────────────────────────────

# ── Google Maps ──────────────────────────────────────────────────
# Required. Used by the frontend for map rendering, Places API,
# and Elevation API. Baked into the Next.js bundle at build time.
#
# Local dev:   set here in .env.local
# Production:  set via: azd env set NEXT_PUBLIC_GOOGLE_MAPS_API_KEY <key>
#              AZD passes it as a Docker --build-arg during azd up / azd deploy
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Fit-Ready-IQ

# ── AZD Deployment (set with 'azd env set', not in this file) ───
# AZURE_ENV_NAME=fit-ready-iq
# AZURE_LOCATION=eastus2
# AZURE_SUBSCRIPTION_ID=74fb4d08-b259-44bb-a495-c81e13d95fc7
# AZURE_RESOURCE_GROUP=rg-sample-fit-maps
# GOOGLE_MAPS_API_KEY=         # stored in Key Vault by azd up
