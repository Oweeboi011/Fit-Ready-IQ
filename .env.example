# ────────────────────────────────────────────────────────────────
# Fit-Ready-IQ — Environment Variables
# Copy this file to .env.local for local development.
# .env.local is gitignored. Never commit real values.
# ────────────────────────────────────────────────────────────────

# ── Google Maps ──────────────────────────────────────────────────
# Required. Used by the frontend for map rendering, Places API,
# and Elevation API. Baked into the Next.js bundle at build time.
#
# Local dev:   set here in .env.local
# Production:  set in Vercel Project Settings -> Environment Variables
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Gemini AI (Chatbot) ─────────────────────────────────────────
# Server-side only — NOT prefixed with NEXT_PUBLIC_.
# Get your key at: https://aistudio.google.com/app/apikey
# Local dev:   set in .env.local
# Production:  set in Vercel Project Settings -> Environment Variables
GEMINI_API_KEY=

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Fit-Ready-IQ

# ── Firebase Auth (Google Sign-In) ───────────────────────────────
# Required for client-side Google login.
# Set these from your Firebase Web App configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (server routes) ───────────────────────────────
# Use one of these auth patterns:
# 1) FIREBASE_SERVICE_ACCOUNT_KEY_JSON (recommended)
# 2) FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Strava server routes ─────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
