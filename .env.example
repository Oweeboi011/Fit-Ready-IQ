# Database Configuration
DB_NAME=fitreadyiq
DB_USER=fitreadyiq_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Application Configuration
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=your_jwt_secret_key_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
ENCRYPTION_KEY=your_encryption_key_for_token_storage

# Azure Key Vault (Production)
AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Strava API Configuration
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/auth/callback/strava
STRAVA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
STRAVA_WEBHOOK_SUBSCRIPTION_ID=

# Garmin API (Future - requires partnership)
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# Komoot API (Requires partner application)
KOMOOT_CLIENT_ID=
KOMOOT_CLIENT_SECRET=

# Mapping & Geolocation APIs
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
MAPBOX_STYLE_URL=mapbox://styles/mapbox/outdoors-v12
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Weather API
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Elevation API
OPEN_ELEVATION_API_URL=https://api.open-elevation.com/api/v1
MAPBOX_ELEVATION_API=true

# Route Data Sources
HIKING_PROJECT_API_KEY=
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Cache TTL (seconds)
CACHE_ACTIVITIES_TTL=900
CACHE_ROUTES_TTL=86400
CACHE_WEATHER_TTL=3600

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=${MAPBOX_ACCESS_TOKEN}
NEXT_PUBLIC_APP_NAME=Fit-Ready-IQ
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Azure Deployment (Production)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=fit-ready-iq-rg
AZURE_LOCATION=eastus
AZURE_APP_SERVICE_NAME=fit-ready-iq-api
AZURE_STATIC_WEB_APP_NAME=fit-ready-iq-web
AZURE_POSTGRES_SERVER_NAME=fit-ready-iq-db
AZURE_POSTGRES_SKU=B_Gen5_1
