# Exclude everything, then whitelist only what the frontend Docker build needs
**

# Re-include frontend source
!frontend/
!frontend/**

# Exclude node_modules and build artifacts from frontend
frontend/node_modules
frontend/.next
frontend/.env*.local
frontend/Dockerfile*
frontend/.dockerignore

# Exclude everything else (already covered by ** but explicit for clarity)
infra/
backend/
docs/
.github/
.git/
*.md
docker-compose*.yml
