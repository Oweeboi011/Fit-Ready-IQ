# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# Strava OAuth 2.0
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# Garmin Connect OAuth 1.0
GARMIN_CONSUMER_KEY=your_garmin_consumer_key
GARMIN_CONSUMER_SECRET=your_garmin_consumer_secret
GARMIN_REDIRECT_URI=http://localhost:3000/api/auth/garmin/callback

# COROS Open API
COROS_CLIENT_ID=your_coros_client_id
COROS_CLIENT_SECRET=your_coros_client_secret
COROS_REDIRECT_URI=http://localhost:3000/api/auth/coros/callback

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Komoot
KOMOOT_CLIENT_ID=your_komoot_client_id
KOMOOT_CLIENT_SECRET=your_komoot_client_secret
